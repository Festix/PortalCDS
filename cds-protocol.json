{
  "device": "CDS Mastermeter",
  "module": "SPP Bluetooth",
  "connection": {
    "baudrate": 9600,
    "dataBits": 8,
    "stopBits": 1,
    "parity": "none",
    "flowControl": "none",
    "connectTimeoutMs": 15000,
    "retry": {
      "maxAttempts": 6,
      "baseDelayMs": 1000,
      "maxDelayMs": 8000,
      "backoffMultiplier": 2
    }
  },
  "protocol": {
    "command": ":v;",
    "responseFormat": ":field0|field1|field2|field3|field4|field5|field6|field7|field8|field9|field10|field11;",
    "header": ":",
    "separator": "|",
    "tail": ";",
    "maxFields": 12
  },
  "polling": {
    "defaultIntervalMs": 4000,
    "minIntervalMs": 1000,
    "maxIntervalMs": 60000
  },
  "fields": [
    {"index": 0, "name": "v", "unit": "--", "type": "string|number", "description": ""},
    {"index": 1, "name": "masa", "unit": "", "type": "number", "description": "masa acumulada"},
    {"index": 2, "name": "caudal", "unit": "g/s", "type": "string|number", "description": "Caudal"},
    {"index": 3, "name": "presion", "unit": "bar", "type": "string|number", "description": "presion"},
    {"index": 4, "name": "temperatura", "unit": "C", "type": "string|number", "description": "temperatura"},
    {"index": 5, "name": "tension", "unit": "V", "type": "string|number", "description": "tension"},
    {"index": 6, "name": "aforador", "unit": "", "type": "string|number", "description": "aforador"},
    {"index": 7, "name": "cargas counter", "unit": "cnt", "type": "number", "description": "cargas"},
    {"index": 8, "name": "unidades", "unit": "unit", "type": "number", "description": "unidades"},
    {"index": 9, "name": "energia", "unit": "conf", "type": "string|number", "description": "energia"},
    {"index": 10, "name": "A/T", "unit": "conf", "type": "string|number", "description": "auto tara"},
    {"index": 11, "name": "", "unit": "", "type": "string|number", "description": ""}
  ]
}
